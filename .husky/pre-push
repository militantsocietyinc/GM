#!/usr/bin/env sh
cd "$(git rev-parse --show-toplevel)" || exit 1

echo "Running type check..."
npm run typecheck || exit 1

echo "Running API type check..."
npm run typecheck:api || exit 1

echo "Running version sync check..."
npm run version:check || exit 1

REMOTE_NAME="${1:-}"
PUSH_REFS="$(cat)"

echo "Running release push guard..."
printf '%s\n' "$PUSH_REFS" | node scripts/release-push-guard.mjs --remote "$REMOTE_NAME" || exit 1
