# ============================================================================
# Philippine Monitor — Environment Variables
# ============================================================================
# Backend (Railway) and Frontend (Netlify) have separate env var contexts.
# This file documents ALL variables across both services.
# ============================================================================

# ┌────────────────────────────────────────────────────────────────────────┐
# │ RAILWAY BACKEND (server/)                                             │
# │ Set these in Railway dashboard: Settings → Variables                  │
# └────────────────────────────────────────────────────────────────────────┘

# === DATABASE (Required) ===
# Neon PostgreSQL connection string
# Get from: https://console.neon.tech → Project → Connection Details
# IMPORTANT: Use the pooled connection string for production
DATABASE_URL=postgresql://user:password@ep-xxx-yyy.region.aws.neon.tech/phmonitor?sslmode=require

# === SERVER CONFIG ===
PORT=3001                          # Railway auto-assigns via $PORT
FRONTEND_URL=https://philippinemonitor.app   # CORS origin allowlist
NODE_ENV=production

# === AI SUMMARIZATION ===
# System tries in order: Groq → OpenRouter → Ollama
# At least one recommended for the Insights panel.

# Groq (cloud — free tier: 14,400 requests/day)
# Register: https://console.groq.com
GROQ_API_KEY=

# OpenRouter (cloud fallback — free tier: 50 requests/day)
# Register: https://openrouter.ai
OPENROUTER_API_KEY=

# Ollama (local — only for local dev, not practical on Railway)
# OLLAMA_API_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b

# === PHILIPPINE DATA SOURCES ===

# ACLED — Armed Conflict Location & Event Data (PH filter)
# Free for researchers — https://acleddata.com/register/
ACLED_ACCESS_TOKEN=

# NASA FIRMS — Satellite fire/hotspot detection
# Free — https://firms.modaps.eosdis.nasa.gov/api/area/
NASA_FIRMS_API_KEY=

# === MARKET DATA ===

# Finnhub — Stock market data (PSE proxy)
# Free tier: 60 calls/min — https://finnhub.io/register
FINNHUB_API_KEY=

# === MARITIME & MILITARY TRACKING ===

# AISStream — Live AIS vessel positions (WebSocket)
# Required for WPS maritime monitoring
# Free — https://aisstream.io
AISSTREAM_API_KEY=

# OpenSky Network — Military aircraft tracking via ADS-B
# Free — https://opensky-network.org
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# Wingbits — Aircraft enrichment (owner, operator, model)
# Contact: https://wingbits.com
WINGBITS_API_KEY=

# === INFRASTRUCTURE ===

# Cloudflare Radar — Internet outage detection (PH filter)
# Free — https://dash.cloudflare.com
CLOUDFLARE_API_TOKEN=


# ┌────────────────────────────────────────────────────────────────────────┐
# │ NETLIFY FRONTEND (frontend/)                                          │
# │ Set in Netlify dashboard: Site → Environment Variables                │
# │ VITE_ prefix required for client-side access                         │
# └────────────────────────────────────────────────────────────────────────┘

# Railway backend URL (dev only — production uses Netlify proxy redirects)
VITE_API_URL=http://localhost:3001

# Railway WebSocket URL (for AIS real-time vessel data)
VITE_WS_URL=ws://localhost:3001

# Default map mode: 'flat' (deck.gl) or '3d' (globe.gl)
VITE_MAP_INTERACTION_MODE=flat

# Sentry DSN for error tracking (empty = disabled)
VITE_SENTRY_DSN=


# ┌────────────────────────────────────────────────────────────────────────┐
# │ LOCAL DEVELOPMENT                                                     │
# │ Copy relevant vars to server/.env and frontend/.env                  │
# └────────────────────────────────────────────────────────────────────────┘
# Option A: Use Neon dev branch
#   DATABASE_URL=postgresql://...@ep-xxx.region.aws.neon.tech/phmonitor_dev?sslmode=require
#
# Option B: Local Postgres via Docker
#   DATABASE_URL=postgresql://postgres:postgres@localhost:5432/phmonitor
